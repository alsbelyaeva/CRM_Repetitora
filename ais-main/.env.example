DATABASE_URL=postgresql://ais_user:ais_password@localhost:5432/ais_db?schema=public
JWT_SECRET=change_me
PORT=4000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# SMTP для восстановления пароля. Если не настроено, ссылка сброса логируется в dev-режиме.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Telegram Bot API. Если не задан, напоминания через Telegram пропускаются без ошибки.
TELEGRAM_BOT_TOKEN=
# Опционально: username бота без @. Если пусто, backend попробует получить его через getMe.
TELEGRAM_BOT_USERNAME=

# 2GIS API для расчета маршрутов и времени дороги.
TWO_GIS_API_KEY=

NODE_ENV=development
# Важно для Docker/Vite-сценариев с доступом из локальной сети.
HOST=0.0.0.0
