DATABASE_URL=postgresql://ais_user:ais_password@db:5432/ais_db
JWT_SECRET=change_me_to_long_random_value
PORT=4000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# SMTP для восстановления пароля и подтверждения email.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Telegram Bot API.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_POLLING_ENABLED=true

# 2GIS API для расчета маршрутов и времени дороги.
TWO_GIS_API_KEY=

# Frontend. Для локального Docker можно оставить пустым:
# Vite будет проксировать API-запросы на backend.
VITE_API_URL=
VITE_PROXY_TARGET=http://backend:4000

# Необязательно: демо-учетные записи, которые создает seed.
SEED_ADMIN_EMAIL=admin@ais.local
SEED_ADMIN_PASSWORD=Admin123
SEED_TEACHER_EMAIL=teacher@ais.local
SEED_TEACHER_PASSWORD=Teacher123
